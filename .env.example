# Example environment configuration (DO NOT COMMIT real secrets)
# Rename to .env and fill in secure values.

# Server
PORT=3001
NODE_ENV=development

# Database
MONGO_URI=YOUR_MONGODB_URI
JWT_SECRET=YOUR_JWT_SECRET

# Admin bootstrap user
ADMIN_EMAIL=admin@registrocivil.gob.do
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Administrador del Sistema

# RNP API Configuration
RNP_BASE_URL_TEST=https://wstest.rnp.hn:1893
RNP_BASE_URL_PROD=https://soapservices.rnp.hn
# Optional default (choose one explicitly in code if needed)
RNP_BASE_URL=https://wstest.rnp.hn:1893

# Production credentials (leave blank here; configure in real .env)
RNP_CODIGO_INSTITUCION=
RNP_CODIGO_SEGURIDAD=
RNP_USUARIO_INSTITUCION=

# Notes:
# - Never commit the real security code or institution identifiers.
# - TEST (PRUEBAS) credentials should be passed explicitly in request body when needed.
# - Rotate JWT_SECRET and RNP_CODIGO_SEGURIDAD periodically.
# - Keep a secure backup of .env in your secrets manager (Vault, AWS Secrets Manager, etc.).
